{
	email {$DOMAIN_EMAIL}
}

{$DOMAIN_URL} {
	encode gzip

	# API и админка PocketBase
	handle /api/* {
		reverse_proxy pocketbase:8090
	}
	handle /_/* {
		reverse_proxy pocketbase:8090
	}

	# llms.txt генерируется бэкендом из каталога упражнений (pb_hooks/llms.pb.js),
	# поэтому отдаём его из PocketBase, а не из статики SPA
	handle /llms.txt {
		reverse_proxy pocketbase:8090
	}

	# Статика SPA (фронтенд gymmate), деплоится rsync'ом в ./www
	handle {
		root * /srv/www

		# Файлы в _app/immutable захэшированы — кэшируем навсегда
		@immutable path /_app/immutable/*
		header @immutable Cache-Control "public, max-age=31536000, immutable"

		# Остальное (index.html, sw, manifest) — только с ревалидацией по ETag,
		# иначе браузер эвристически кэширует HTML и после деплоя виден старый фронт
		@mutable not path /_app/immutable/*
		header @mutable Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}
}
